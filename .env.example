# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your_token_here

# MongoDB connection string (MongoDB Atlas free tier works great)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/vat_bot?retryWrites=true&w=majority

# MongoDB database name
MONGODB_DB=vat_bot

# Optional: request timeout for soliq.uz (seconds)
SOLIQ_TIMEOUT=15

# Optional: MongoDB server selection timeout during startup (milliseconds)
MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000
