# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your_token_here

# MongoDB connection string (MongoDB Atlas free tier works great)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/vat_bot?retryWrites=true&w=majority

# MongoDB database name
MONGODB_DB=vat_bot

# Optional: request timeout for soliq.uz (seconds)
SOLIQ_TIMEOUT=15

# Optional: MongoDB server selection timeout during startup (milliseconds)
MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000

# Optional: save raw/cropped debug images on disk (1=true, 0=false)
SAVE_DEBUG_IMAGES=0

# Optional: HTTP/HTTPS proxy for soliq.uz only (e.g., when WiFi ISP blocks it)
# SOLIQ_PROXY=http://127.0.0.1:8888

# Support contact shown in welcome + failure messages. Use a clickable
# Telegram handle (e.g. @ShiraliDT) for best UX.
SUPPORT_CONTACT=Shirali DT

# Comma-separated Telegram user IDs allowed to call hidden technical-admin
# commands like /heartcheck. Leave empty to disable that surface entirely.
# ADMIN_TELEGRAM_IDS=7962068286

# Comma-separated Telegram user IDs of DT staff who approve new-user
# requests. When someone runs /start for the first time, these people are
# pinged with Approve/Deny buttons. To collect IDs, ask each DT staffer to
# message the bot with /whoami once and read off the number.
# APPROVER_TELEGRAM_IDS=7962068286
